# gua env (Postgres backend). Postgres is the only backend.
GRPC_LISTEN=:6666
HTTP_LISTEN=:7777
MACHINE_CODE=IAMYM55

# Postgres connection (River runs its own migrations on startup)
PG_DSN=postgres://postgres:gua@127.0.0.1:5432/gua?sslmode=disable

# Execution-history retention (seconds; default 5 days, 0 disables)
GUA_HISTORY_TTL=432000

# Logging (slog)
LOG_OUTPUT=stdout            # stdout | file | both
LOG_FILE=gua.log             # used when LOG_OUTPUT=file|both
LOG_FORMAT=json              # json | text
LOG_LEVEL=info               # debug | info | warn | error
# file rotation (lumberjack; only when writing to a file)
LOG_ROTATE_MAX_SIZE_MB=100   # rotate after this many MB
LOG_ROTATE_MAX_BACKUPS=7     # keep at most N rotated files
LOG_ROTATE_MAX_AGE_DAYS=30   # delete rotated files older than N days
LOG_ROTATE_COMPRESS=false    # gzip rotated files
