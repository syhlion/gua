        <mxCell id="title" value="gua cluster on Postgres — stateless horizontal scaling (no slot election)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nodeA" value="gua node A&#xa;(stateless)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="nodeB" value="gua node B&#xa;(stateless)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="400" y="90" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="nodeC" value="gua node C&#xa;(stateless)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="740" y="90" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pg" value="PostgreSQL&#xa;river_job · gua_jobs · gua_executions" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="360" y="260" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="ea" value="FOR UPDATE&#xa;SKIP LOCKED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;startFill=1;exitX=0.5;exitY=1;entryX=0.15;entryY=0;fontSize=10;" edge="1" parent="1" source="nodeA" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb" value="SKIP LOCKED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;startFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="nodeB" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec" value="SKIP LOCKED" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;startArrow=classic;startFill=1;exitX=0.5;exitY=1;entryX=0.85;entryY=0;fontSize=10;" edge="1" parent="1" source="nodeC" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note" value="Why this is simpler than the Redis version&#xa;• No per-server buckets, no SERVER-N slot election, no owner-token fencing,&#xa;  no down-server reclaim, no de-dup fence — Postgres row locks do the coordination.&#xa;• SKIP LOCKED guarantees each job is dequeued by exactly one node. Add a node → it just&#xa;  starts pulling. A crashed node's in-flight jobs are reclaimed by River's rescuer.&#xa;• River runs its own leader election (PG advisory locks) for singleton maintenance&#xa;  (scheduler / rescuer) — gua does not implement it.&#xa;• Delivery is at-least-once (retry / rescue) — consumers stay idempotent." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="410" width="840" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
