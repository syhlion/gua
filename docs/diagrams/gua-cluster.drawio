<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="gua-cluster">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="620" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="gua cluster — slot fencing &amp; failover (HA)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nodeA" value="gua node A&#xa;slot SERVER-1&#xa;owner token T_A&#xa;snowflake node = 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="nodeB" value="gua node B&#xa;slot SERVER-2&#xa;owner token T_B&#xa;snowflake node = 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="680" y="90" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Redis&#xa;&#xa;SERVER-N  (heartbeat ts)&#xa;OWN-SERVER-N  (owner token)&#xa;down-server  (LIST)&#xa;JOB-*-scan  (checkpoints)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="370" y="80" width="220" height="140" as="geometry" />
        </mxCell>
        <mxCell id="hbA" value="heartbeat CAS (1s)&#xa;refresh SERVER-1 iff OWN==T_A" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.35;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="nodeA" target="redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="hbB" value="heartbeat CAS (1s)&#xa;refresh SERVER-2 iff OWN==T_B" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.35;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="nodeB" target="redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note_fence" value="Fencing — no snowflake node-id collision&#xa;The heartbeat is a CAS: it refreshes the slot only while&#xa;OWN-SERVER-N still holds this node's token. If a peer&#xa;reclaimed the slot during a long pause, the next heartbeat&#xa;(≤1s) sees the mismatch → OnSupersede → process exits&#xa;instead of generating colliding ids." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="note_reclaim" value="Failover — orphaned work is reclaimed&#xa;A dying node's bucket goroutines LPUSH their bucket&#xa;names to down-server. A surviving peer LPOPs and&#xa;ZUNIONSTORE-merges those buckets into its own, so&#xa;the dead node's jobs keep firing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="490" y="280" width="420" height="120" as="geometry" />
        </mxCell>
        <mxCell id="note_jobcheck" value="JobCheck — backstop for lost jobs&#xa;Every 30–60s one node takes the JOBCHECKLOCK (TTL + owner-token lock, self-releases on crash),&#xa;scans JOB-*-scan checkpoints, and re-pushes any active job that fell out of bucket rotation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="870" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
